#!/usr/bin/env sh
set -eu

usage() {
	cat <<'EOF'
Usage:
  contracts/plugin-bundle/src/adapters/scaffold-plugin-bundle --bundle-id ID --src-root DIR --out DIR [--force]

Scaffolds a plugin-bundle contract slice using the shared contracts/meta scaffold.
EOF
}

bundle_id=""
src_root=""
out=""
force="false"

while [ "$#" -gt 0 ]; do
	case "$1" in
		--bundle-id)
			bundle_id="${2:-}"
			shift 2
			;;
		--src-root)
			src_root="${2:-}"
			shift 2
			;;
		--out)
			out="${2:-}"
			shift 2
			;;
		--force)
			force="true"
			shift
			;;
		--help|-h)
			usage
			exit 0
			;;
		*)
			echo "unknown argument: $1" >&2
			usage >&2
			exit 2
			;;
	esac
done

if [ -z "$bundle_id" ]; then
	echo "--bundle-id is required" >&2
	exit 2
fi

if [ -z "$src_root" ]; then
	echo "--src-root is required" >&2
	exit 2
fi

if [ ! -d "$src_root" ]; then
	echo "--src-root must point at an existing directory" >&2
	exit 2
fi

if [ -z "$out" ]; then
	echo "--out is required" >&2
	exit 2
fi

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/../../../.." && pwd)

set --
if [ "$force" = "true" ]; then
	set -- --force
fi

"$repo_root/contracts/meta/scripts/scaffold-contract-slice" \
	--slice-id "$bundle_id" \
	--title "$bundle_id plugin bundle" \
	--out "$out" \
	"$@"

python3 - "$bundle_id" "$out" <<'PY'
import json
import sys
from pathlib import Path

bundle_id, out = sys.argv[1:3]
root = Path(out)

manifest = root / "manifest.cue"
checks = root / "checks" / "manifest.cue"

replacements = {
    "contractSliceManifest": "pluginBundleContract",
    "contractSliceValidationPlan": "pluginBundleValidationPlan",
    "contractSliceCompletionReport": "pluginBundleCompletionReport",
}

for path in (manifest, checks):
    text = path.read_text()
    for old, new in replacements.items():
        text = text.replace(old, new)
    if path == manifest:
        text = text.replace(
            'import impl "github.com/fatb4f/factory/contracts/meta"',
            'import (\n\timpl "github.com/fatb4f/factory/contracts/meta"\n\ttmpl "github.com/fatb4f/factory/contracts/plugin-bundle/src:pluginbundlesrc"\n)',
        )
        text = text.replace(
            "\npluginBundleContract: {\n",
            "\npluginBundleContractProjection: tmpl.#PluginBundleContractProjectionLayout & {\n\tpluginName: _sliceID\n}\n\npluginBundleGeneratedProjection: tmpl.#PluginBundleGeneratedProjectionLayout & {\n\tpluginName: _sliceID\n}\n\npluginBundleContract: {\n",
        )
        text = text.replace(
            "\tid:       _sliceID\n\ttitle:    _title\n",
            "\tid:                  _sliceID\n\ttitle:               _title\n\tcontractProjection:  pluginBundleContractProjection\n\tgeneratedProjection: pluginBundleGeneratedProjection\n",
        )
    path.write_text(text)

generated_root = root.parent.parent / "generated" / bundle_id
plugin_root = generated_root
(plugin_root / ".codex-plugin").mkdir(parents=True, exist_ok=True)
(plugin_root / "skills").mkdir(parents=True, exist_ok=True)
(plugin_root / "hooks").mkdir(parents=True, exist_ok=True)
(plugin_root / "scripts").mkdir(parents=True, exist_ok=True)

(plugin_root / ".codex-plugin" / "plugin.json").write_text(json.dumps({
    "schema": "codex.plugin.v1",
    "name": bundle_id,
    "version": "0.0.0",
    "description": f"Generated {bundle_id} plugin bundle scaffold.",
    "skills": "skills",
    "hooks": "hooks",
    "scripts": "scripts",
}, indent=2) + "\n")

(plugin_root / "skills" / "SKILL.md").write_text(f"""---
name: {bundle_id}
description: Generated scaffold skill for the {bundle_id} plugin bundle.
---

# {bundle_id}

Replace this scaffold skill with the plugin bundle's concrete skill instructions.
""")

(plugin_root / "hooks" / "hooks.json").write_text(json.dumps({
    "schema": "codex.plugin.hooks.v1",
    "hooks": []
}, indent=2) + "\n")

(plugin_root / "scripts" / "README.md").write_text(f"""# {bundle_id} scripts

Generated placeholder for plugin bundle scripts.
""")
PY
