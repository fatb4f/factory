#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
repo_root=$script_dir
while [ "$repo_root" != "/" ] && [ ! -d "$repo_root/.git" ]; do
	repo_root=$(CDPATH= cd -- "$repo_root/.." && pwd -P)
done

[ -d "$repo_root/.git" ] || {
	printf 'agent-context-resolver-hook: repository root not found\n' >&2
	exit 2
}

export CONTRACT_FACTORY_ROOT=$repo_root
exec "$repo_root/contracts/agent-context-resolver/projections/codex/skills/resolve-agent-context/scripts/agent-context-resolver-hook" "$@"
