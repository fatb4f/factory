#!/usr/bin/env sh
set -eu
slice_id=""
title=""
out=""
force="false"
while [ "$#" -gt 0 ]; do
	case "$1" in
		--slice-id) slice_id="${2:-}"; shift 2 ;;
		--title) title="${2:-}"; shift 2 ;;
		--out) out="${2:-}"; shift 2 ;;
		--force) force="true"; shift ;;
		*) echo "unsupported scaffold argument: $1" >&2; exit 2 ;;
	esac
done
just scaffold-contract-slice "$slice_id" "$title" "$out" "$force"
