package agentcontextresolver

_negativeBottomChecks: {
	hookTemplate: {
		generatedProjectionAuthority:
			hookTemplateNegativeFixtures.generatedProjectionAuthority.input & #GeneratedHookProjection

		shellSemanticAuthority:
			hookTemplateNegativeFixtures.shellSemanticAuthority.input & #EvalRunnerPlan

		emptyRunnerCommand:
			hookTemplateNegativeFixtures.emptyRunnerCommand.input & #RunnerCommand

		undeclaredRunnerCommand:
			hookTemplateNegativeFixtures.undeclaredRunnerCommand.input & #EvalRunnerPlan

		stringifiedBottomCheck:
			hookTemplateNegativeFixtures.stringifiedBottomCheck.input & #EvalPlan
	}
}
