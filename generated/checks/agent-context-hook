#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/../.." && pwd -P)
cd "$repo_root"

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

packet_file=$tmp_dir/agent-context-hook.packet.json
observed_packet=generated/evidence/agent-context-hook.packet.json
assertion_results=generated/evidence/assertion-results.json

rm -f "$assertion_results"

prompt=$(jq -r '.prompt' generated/fixtures/agent-context-hook-prompt.json)
.codex/skills/resolve-agent-context/scripts/resolve-agent-context --prompt "$prompt" >"$packet_file"

packet_bytes=$(wc -c <"$packet_file" | tr -d ' ')

materialization_report=generated/evidence/materialization-report.json
source_digest=$(jq -r '.provenance.sourceDigest' "$materialization_report")
inventory_digest=$(jq -r '.provenance.inventoryDigest' "$materialization_report")
run_id=$(jq -r '.provenance.materializedAt' "$materialization_report")

jq -n \
	--slurpfile packet "$packet_file" \
	--argjson packetBytes "$packet_bytes" \
	--arg sourceDigest "$source_digest" \
	--arg inventoryDigest "$inventory_digest" \
	--arg runID "$run_id" \
	'{
		schema: "factory.observed-packet-evidence.v1",
		id: "factory.validation.evidence.agent-context-hook-packet",
		assertionID: "factory.validation.agent-context-hook",
		packetBytes: $packetBytes,
		packet: $packet[0],
		provenance: {
			origin: "reflection",
			reflector: "factory.validation-reflector.v1",
			sourceDigest: $sourceDigest,
			inventoryDigest: $inventoryDigest,
			materializedAt: $runID
		}
	}' >"$observed_packet"

status=pass
if [ "$packet_bytes" -ge 50000 ]; then
	status=fail
fi

if [ "$status" = pass ]; then
	if ! (
		cd contracts/factory
		cue eval ./assertions/generated -e agentContextHookAssertion -c >/dev/null
		cue vet -c -d '#AgentContextHookPacket' ./assertions/generated "$packet_file"
		cue vet -c -d '#CodexHooksProjection' ./assertions/generated "$repo_root/.codex/hooks.json"
		cue vet -c -d '#ValidationFixture' ./assertions "$repo_root/generated/fixtures/agent-context-hook-prompt.json"
		cue vet -c -d '#MaterializationReport' ./assertions "$repo_root/generated/evidence/materialization-report.json"
		cue vet -c -d '#ObservedPacketEvidence' ./assertions "$repo_root/generated/evidence/agent-context-hook.packet.json"
		cue eval . -e materializationPlan -c >/dev/null
	); then
		status=fail
	fi
fi

jq -n \
	--arg status "$status" \
	--arg sourceDigest "$source_digest" \
	--arg inventoryDigest "$inventory_digest" \
	--arg runID "$run_id" \
	'{
		schema: "factory.assertion-results.v1",
		provenance: {
			origin: "reflection",
			reflector: "factory.validation-reflector.v1",
			sourceDigest: $sourceDigest,
			inventoryDigest: $inventoryDigest,
			materializedAt: $runID
		},
		results: [{
			id: "factory.validation.result.agent-context-hook",
			assertionID: "factory.validation.agent-context-hook",
			status: $status,
			evidence: [
				"generated/evidence/materialization-report.json",
				"generated/evidence/agent-context-hook.packet.json",
				"generated/checks/agent-context-hook"
			]
		}]
	}' >"$assertion_results"

(
	cd contracts/factory
	cue vet -c -d '#AssertionResultProjection' ./assertions "$repo_root/generated/evidence/assertion-results.json"
)

[ "$status" = pass ]
